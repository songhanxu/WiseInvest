# Server Configuration
SERVER_PORT=8080
SERVER_MODE=debug

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=wiseinvest
DB_PASSWORD=wiseinvest
DB_NAME=wiseinvest
DB_SSLMODE=disable

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# OpenAI Configuration
OPENAI_API_KEY=sk-346bc09748fb4cf4898597b67b2ad8f4
OPENAI_MODEL=deepseek-reasoner
OPENAI_BASE_URL=https://api.deepseek.com/v1

# Web Search Configuration (enables real-time data for market agents)
# Providers: serper (https://serper.dev) | brave (https://brave.com/search/api)
# Free tiers available for both. Leave empty to disable.
SEARCH_PROVIDER=serper
SEARCH_API_KEY=741b50fc400c48edf517e162557e89b45d966c57

# Binance Configuration
# Get your API keys from: https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here
BINANCE_BASE_URL=https://api.binance.com
# Set to true to use Binance Testnet (recommended for development)
BINANCE_TESTNET=true

# JWT Configuration
JWT_SECRET=change-me-in-production
JWT_EXPIRATION=24h

# WeChat OAuth Configuration
# Register at https://open.weixin.qq.com/ to get your AppID and AppSecret
WECHAT_APP_ID=your_wechat_app_id_here
WECHAT_APP_SECRET=your_wechat_app_secret_here

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000
WXWORK_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=a499d149-f0ec-4752-85b8-9e04c9d9157b

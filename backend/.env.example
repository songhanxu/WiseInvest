# Server Configuration
SERVER_PORT=8080
SERVER_MODE=debug

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=wiseinvest
DB_PASSWORD=wiseinvest
DB_NAME=wiseinvest
DB_SSLMODE=disable

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# OpenAI / LLM Configuration
# DeepSeek: https://platform.deepseek.com/api_keys
# OpenAI:   https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_or_deepseek_api_key_here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_BASE_URL=https://api.openai.com/v1

# Web Search Configuration
# Providers: serper (https://serper.dev) | brave (https://brave.com/search/api)
# Leave empty to disable real-time search.
SEARCH_PROVIDER=serper
SEARCH_API_KEY=your_search_api_key_here

# Binance Configuration
# https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here
BINANCE_BASE_URL=https://api.binance.com
BINANCE_TESTNET=true

# JWT Configuration
JWT_SECRET=change-me-in-production
JWT_EXPIRATION=24h

# WeChat OAuth Configuration
# https://open.weixin.qq.com/
WECHAT_APP_ID=your_wechat_app_id_here
WECHAT_APP_SECRET=your_wechat_app_secret_here

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ── Push Notifications ────────────────────────────────────────────────────────

# 企业微信机器人 Webhook
# 在企业微信群 → 群机器人 → 添加 → 复制 Webhook 地址
WXWORK_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your_key_here

# APNs (iOS 推送) — token-based (.p8) 认证
# 从 Apple Developer 后台获取：Certificates, Identifiers & Profiles → Keys
APNS_KEY_ID=your_apns_key_id_here
APNS_TEAM_ID=your_apple_team_id_here
APNS_BUNDLE_ID=com.yourcompany.wiseinvest
APNS_KEY_FILE=apns_key.p8
APNS_PRODUCTION=false

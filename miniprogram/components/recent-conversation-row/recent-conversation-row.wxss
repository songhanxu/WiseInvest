.row {
  background: linear-gradient(180deg, rgba(20, 34, 61, 0.86) 0%, rgba(15, 25, 46, 0.86) 100%);
  border: 1rpx solid rgba(131, 158, 210, 0.2);
  border-radius: 22rpx;
  padding: 22rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 14rpx;
}

.icon-box {
  width: 84rpx;
  height: 84rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: 600;
}

.meta {
  flex: 1;
  min-width: 0;
}

.title {
  color: #f6faff;
  font-size: 29rpx;
  font-weight: 500;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.time {
  margin-top: 6rpx;
  color: rgba(166, 186, 229, 0.78);
  font-size: 23rpx;
}

.arrow {
  color: rgba(166, 186, 229, 0.72);
  font-size: 34rpx;
}

.market-card {
  position: relative;
  height: 278rpx;
  border-radius: 30rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 16rpx 34rpx rgba(0, 0, 0, 0.3);
}

.market-card::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(120deg, rgba(255, 255, 255, 0.18) 0%, rgba(255, 255, 255, 0) 45%);
  pointer-events: none;
}

.market-icon {
  position: absolute;
  right: 28rpx;
  top: 16rpx;
  font-size: 118rpx;
  opacity: 0.16;
}

.market-content {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.market-name {
  font-size: 54rpx;
  line-height: 1.04;
  font-weight: 700;
  color: #ffffff;
}

.market-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.76);
}

.market-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

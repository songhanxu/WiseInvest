.bubble-row {
  display: flex;
  width: 100%;
  margin-bottom: 24rpx;
}

.row-user {
  justify-content: flex-end;
}

.row-assistant {
  justify-content: flex-start;
}

.bubble-wrap {
  max-width: 90%;
}

.bubble {
  padding: 20rpx 22rpx;
  border-radius: 22rpx;
  white-space: pre-wrap;
  word-break: break-word;
}

.bubble-user {
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  color: #ffffff;
  border-bottom-right-radius: 8rpx;
  box-shadow: 0 10rpx 22rpx rgba(37, 99, 235, 0.3);
}

.bubble-assistant {
  background: linear-gradient(180deg, rgba(22, 36, 65, 0.92) 0%, rgba(17, 30, 55, 0.92) 100%);
  border: 1rpx solid rgba(131, 158, 210, 0.2);
  color: #edf4ff;
  border-bottom-left-radius: 8rpx;
}

.thinking-box {
  background: rgba(2, 8, 23, 0.34);
  border: 1rpx solid rgba(138, 164, 217, 0.2);
  border-radius: 12rpx;
  padding: 12rpx;
  margin-bottom: 12rpx;
}

.thinking-line {
  color: rgba(170, 188, 228, 0.88);
  font-size: 23rpx;
  line-height: 1.45;
}

.content {
  line-height: 1.62;
  font-size: 29rpx;
}

.streaming {
  margin-top: 10rpx;
  color: rgba(170, 188, 228, 0.78);
  letter-spacing: 6rpx;
}

.meta {
  margin-top: 10rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  color: rgba(151, 173, 218, 0.82);
}

.meta-user {
  justify-content: flex-end;
}

.meta-assistant {
  justify-content: flex-start;
}

.time {
  font-size: 21rpx;
}

.actions {
  display: flex;
  gap: 12rpx;
}

.action {
  font-size: 22rpx;
}

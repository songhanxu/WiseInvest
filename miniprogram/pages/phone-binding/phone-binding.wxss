.phone-page {
  min-height: 100vh;
  padding: 60rpx 48rpx;
  background: #0a0e1a;
}

.header-icon {
  width: 144rpx;
  height: 144rpx;
  margin: 24rpx auto;
  border-radius: 72rpx;
  background: #1e3a5f;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
}

.title {
  text-align: center;
  color: #fff;
  font-size: 50rpx;
  font-weight: 700;
}

.subtitle {
  margin-top: 12rpx;
  text-align: center;
  color: #64748b;
  font-size: 26rpx;
}

.form-card {
  margin-top: 44rpx;
}

.field-title {
  color: #94a3b8;
  font-size: 24rpx;
  margin-bottom: 10rpx;
}

.phone-row,
.code-row {
  display: flex;
  gap: 14rpx;
  margin-bottom: 20rpx;
}

.code {
  width: 110rpx;
  background: #1e293b;
  border-radius: 18rpx;
  color: #94a3b8;
  display: flex;
  align-items: center;
  justify-content: center;
}

.phone-input,
.code-input {
  flex: 1;
  height: 88rpx;
  background: #1e293b;
  border-radius: 18rpx;
  color: #fff;
  font-size: 30rpx;
  padding: 0 20rpx;
}

.resend {
  width: 168rpx;
  height: 88rpx;
  line-height: 88rpx;
  border: none;
  border-radius: 18rpx;
  background: #1e293b;
  color: #3b82f6;
  font-size: 26rpx;
  padding: 0;
}

.resend[disabled] {
  color: #475569;
}

.primary {
  margin-top: 10rpx;
  width: 100%;
  height: 98rpx;
  line-height: 98rpx;
  border: none;
  border-radius: 22rpx;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  background: linear-gradient(90deg, #3b82f6, #1d4ed8);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
}

.primary::after {
  border: none;
}

.primary[disabled] {
  opacity: 0.6;
}

.skip {
  margin-top: 30rpx;
  text-align: center;
  color: #475569;
  font-size: 26rpx;
}

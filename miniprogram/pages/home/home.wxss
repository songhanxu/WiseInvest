.home-page {
  position: relative;
  min-height: 100vh;
  background-color: #081227;
  overflow: hidden;
  background:
    radial-gradient(900rpx 520rpx at 18% -10%, rgba(74, 144, 226, 0.34) 0%, rgba(74, 144, 226, 0) 70%),
    radial-gradient(800rpx 520rpx at 100% 0%, rgba(56, 189, 248, 0.2) 0%, rgba(56, 189, 248, 0) 75%),
    linear-gradient(180deg, #081227 0%, #090f1e 45%, #070d19 100%);
}

.home-glow {
  position: absolute;
  border-radius: 999rpx;
  filter: blur(88rpx);
  opacity: 0.32;
  pointer-events: none;
}

.home-glow-1 {
  width: 460rpx;
  height: 460rpx;
  left: -180rpx;
  top: 220rpx;
  background: #3b82f6;
}

.home-glow-2 {
  width: 520rpx;
  height: 520rpx;
  right: -220rpx;
  top: 360rpx;
  background: #0ea5e9;
}

.content {
  position: relative;
  z-index: 2;
  padding: 38rpx 34rpx 42rpx;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 34rpx;
}

.title-cn {
  font-size: 64rpx;
  line-height: 1.06;
  font-weight: 700;
  color: #ffffff;
}

.title-en {
  margin-top: 8rpx;
  color: rgba(197, 214, 255, 0.74);
  font-size: 27rpx;
  letter-spacing: 1.2rpx;
}

.avatar-btn {
  width: 82rpx;
  height: 82rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(144, 177, 255, 0.4);
  background: rgba(16, 30, 58, 0.92);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.28);
}

.avatar-glyph {
  width: 42rpx;
  height: 42rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.avatar-head {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #cfe1ff;
}

.avatar-body {
  width: 26rpx;
  height: 14rpx;
  margin-top: 4rpx;
  border-radius: 14rpx 14rpx 8rpx 8rpx;
  background: #cfe1ff;
}

.section-title {
  color: #f8fbff;
  font-size: 35rpx;
  font-weight: 600;
}

.section-subtitle {
  margin-top: 8rpx;
  color: rgba(169, 190, 233, 0.74);
  font-size: 23rpx;
}

.markets {
  margin-top: 18rpx;
}

.recent-title-wrap {
  margin-top: 8rpx;
}

.recent-list {
  margin-top: 14rpx;
  padding-bottom: 12rpx;
}

.recent-empty {
  margin-top: 16rpx;
  border: 1rpx dashed rgba(137, 165, 220, 0.34);
  border-radius: 24rpx;
  padding: 34rpx 26rpx;
  background: rgba(14, 24, 44, 0.48);
}

.empty-title {
  color: #d8e7ff;
  font-size: 29rpx;
  font-weight: 500;
}

.empty-desc {
  margin-top: 8rpx;
  color: rgba(169, 190, 233, 0.72);
  font-size: 23rpx;
}

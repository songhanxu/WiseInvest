.conversation-page {
  position: fixed;
  inset: 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  background-color: #081227;
  background:
    radial-gradient(760rpx 440rpx at 100% -8%, rgba(56, 189, 248, 0.16) 0%, rgba(56, 189, 248, 0) 74%),
    linear-gradient(180deg, #081227 0%, #0a1020 100%);
}

.header {
  border-bottom: 1rpx solid rgba(138, 164, 217, 0.18);
  background: linear-gradient(180deg, rgba(11, 23, 45, 0.94) 0%, rgba(9, 17, 33, 0.92) 100%);
  backdrop-filter: blur(10rpx);
}

.header-inner {
  height: 100rpx;
  padding: 0 22rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.back,
.menu {
  width: 60rpx;
  height: 60rpx;
  line-height: 60rpx;
  border-radius: 30rpx;
  text-align: center;
  color: #dce9ff;
  font-size: 40rpx;
  background: rgba(53, 85, 143, 0.28);
}

.market-icon {
  width: 60rpx;
  height: 60rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #4a90e2 0%, #2563eb 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  box-shadow: 0 10rpx 20rpx rgba(37, 99, 235, 0.32);
}

.market-meta {
  flex: 1;
  min-width: 0;
}

.market-name {
  color: #f8fbff;
  font-size: 31rpx;
  font-weight: 600;
}

.market-subtitle {
  color: rgba(175, 196, 233, 0.78);
  font-size: 22rpx;
  margin-top: 4rpx;
}

.message-scroll {
  flex: 1;
  min-height: 0;
}

.messages {
  padding: 24rpx 22rpx 170rpx;
}

.bottom-anchor {
  height: 2rpx;
}

.error-banner {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 114rpx;
  margin: 0;
  padding: 16rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(252, 165, 165, 0.38);
  background: rgba(127, 29, 29, 0.42);
  color: #ffe7e7;
  font-size: 25rpx;
  z-index: 31;
}

.input-wrap {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 30;
  display: flex;
  align-items: flex-end;
  gap: 12rpx;
  padding: 12rpx 18rpx calc(14rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(138, 164, 217, 0.18);
  background: rgba(8, 14, 27, 0.96);
}

.input-box {
  flex: 1;
  min-width: 0;
}

.input {
  width: 100%;
  min-height: 84rpx;
  max-height: 260rpx;
  background: linear-gradient(180deg, rgba(23, 37, 66, 0.92) 0%, rgba(17, 29, 53, 0.9) 100%);
  border: 1rpx solid rgba(130, 157, 210, 0.26);
  border-radius: 24rpx;
  padding: 20rpx 22rpx;
  color: #f3f7ff;
  font-size: 30rpx;
  line-height: 1.52;
  box-sizing: border-box;
}

.send {
  flex: 0 0 106rpx;
  width: 106rpx;
  min-width: 106rpx;
  max-width: 106rpx;
  height: 84rpx;
  line-height: 84rpx;
  border: none;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 600;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 22rpx rgba(37, 99, 235, 0.35);
}

.send::after {
  border: none;
}

.send[disabled] {
  opacity: 0.45;
  box-shadow: none;
}
